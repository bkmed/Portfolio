{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "checkJs": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./*"],
      "@common/*": ["./src/app/_common/*"],
      "@styles/*": ["./src/app/_styles/*"],
      "@components/*": ["./src/app/_components/*"],
      "@layouts/*": ["./src/app/_layouts/*"],
      "@library/*": ["./src/app/_lib/*"],
      "@data/*": ["./src/data/*"]
    }
  },
  "exclude": ["node_modules", ".next", "out"]
}
